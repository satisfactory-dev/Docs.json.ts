# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = tab
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[data/**/*.json]
charset = utf-16le

[data/migration.json]
charset = utf-8

[data/migration-short.json]
charset = utf-8

[data/1.0.1.4/Docs/io.json]
charset = utf-8

[data/**/*.utf8.json]
charset = utf-8

[package.json]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 4
