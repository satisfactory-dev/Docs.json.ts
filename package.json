{
  "type": "module",
  "name": "@satisfactory-dev/docs.json.ts",
  "description": "TypeScript mappings for the Docs.json file that ships with Satisfactory",
  "license": "Apache-2.0",
  "keywords": [
    "satisfactory",
    "Docs.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SignpostMarv/nodejs-template.git"
  },
  "funding": "https://github.com/SignpostMarv/nodejs-template?sponsor=1",
  "engines": {
    "node": "^25.0"
  },
  "devDependencies": {
    "@satisfactory-dev/ajv-utilities": "^0.22.0",
    "@signpostmarv/oxlint-config": "^0.3.1",
    "@types/node": "^25.6.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "prettier": "^3.5.3"
  },
  "peerDependencies": {
    "@satisfactory-dev/predicates.ts": "^0.3.0",
    "@signpostmarv/js-types": "^0.2.0",
    "@signpostmarv/json-schema-typescript-codegen": "^0.11.0",
    "ajv": "^8.18.0",
    "typescript": "^6.0.2"
  },
  "files": [
    "./src/**/*.ts",
    "./src/**/*.js",
    "./src/**/*.js.map",
    "./schema/**/*.json",
    "./generated-types/*/classes/*.ts",
    "./generated-types/*/classes/*.js",
    "./generated-types/*/classes/*.js.map",
    "./generated-types/*/types/*.ts",
    "./generated-types/*/types/*.js",
    "./generated-types/*/types/*.js.map",
    "./generated-types/*/classes.ts",
    "./generated-types/*/classes.d.ts",
    "./generated-types/*/classes.js",
    "./generated-types/*/classes.js.map",
    "./generated-types/*/types.ts",
    "./generated-types/*/types.d.ts",
    "./generated-types/*/types.js",
    "./generated-types/*/types.js.map",
    "./generated-types/*/properties.ts",
    "./generated-types/*/properties.d.ts",
    "./generated-types/*/properties.js",
    "./generated-types/*/properties.js.map",
    "./generated-types/*/Base.ts",
    "./generated-types/*/Base.d.ts",
    "./generated-types/*/Base.js",
    "./generated-types/*/Base.js.map",
    "./generated-types/lib/**/*.ts",
    "./generated-types/lib/**/*.js",
    "./generated-types/lib/**/*.map"
  ]
}
