{
  "type": "module",
  "name": "@satisfactory-dev/docs.json.ts",
  "description": "TypeScript mappings for the Docs.json file that ships with Satisfactory",
  "license": "Apache-2.0",
  "keywords": [
    "satisfactory",
    "Docs.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SignpostMarv/nodejs-template.git"
  },
  "funding": "https://github.com/SignpostMarv/nodejs-template?sponsor=1",
  "engines": {
    "node": "^25.0"
  },
  "devDependencies": {
    "@signpostmarv/oxlint-config": "^0.1.0",
    "@types/node": "^24.6.2",
    "@types/regexp.escape": "^2.0.0",
    "c8": "^10.1.3",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0",
    "prettier": "^3.5.3",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@satisfactory-dev/predicates.ts": "^0.2.2",
    "@signpostmarv/json-schema-typescript-codegen": "^0.8.0",
    "ajv": "^8.17.1"
  },
  "files": [
    "./src/**/*.ts",
    "./src/**/*.js",
    "./src/**/*.js.map",
    "./schema/**/*.json",
    "./generated-types/**/*.ts",
    "./generated-types/**/*.js",
    "./generated-types/**/*.js.map",
    "!./generated-types/**/data.ts",
    "!./generated-types/**/data.js",
    "!./generated-types/**/data.js.map"
  ]
