{
	"extends": "./tsconfig",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"emitDeclarationOnly": false,
		"rewriteRelativeImportExtensions": true,
		"sourceMap": true
	},
	"include": ["./src/**/*.ts", "./generated-types/**/*.ts"],
	"exclude": [
		"./generated-types/**/data.ts",
		"./generated-types/**/*.data.ts"
	]
}
