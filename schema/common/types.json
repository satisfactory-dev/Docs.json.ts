{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "docs.json.ts--common--types",
	"$defs": {
		"bool_string": {
			"type": "string",
			"enum": ["False", "True"]
		},
		"decimal_string": {
			"type": "string",
			"pattern": "^\\d+\\.\\d{6}$"
		},
		"decimal_string--signed": {
			"type": "string",
			"pattern": "^-?\\d+\\.\\d{6}$"
		},
		"integer_string": {
			"type": "string",
			"pattern": "^\\d+$"
		},
		"BGRA": {
			"type": "string",
			"typed_string": {
				"type": "object",
				"additionalProperties": false,
				"required": ["B", "G", "R", "A"],
				"properties": {
					"B": {
						"$ref": "#/$defs/integer_string"
					},
					"G": {
						"$ref": "#/$defs/integer_string"
					},
					"R": {
						"$ref": "#/$defs/integer_string"
					},
					"A": {
						"$ref": "#/$defs/integer_string"
					}
				}
			}
		},
		"XYZ--decimal_string": {
			"type": "string",
			"typed_string": {
				"type": "object",
				"additionalProperties": false,
				"required": ["X", "Y", "Z"],
				"properties": {
					"X": {
						"$ref": "#/$defs/decimal_string"
					},
					"Y": {
						"$ref": "#/$defs/decimal_string"
					},
					"Z": {
						"$ref": "#/$defs/decimal_string"
					}
				}
			}
		},
		"empty-object": {
			"type": "string",
			"const": "()"
		}
	}
}
