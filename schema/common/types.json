{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "docs.json.ts--common--types",
	"$defs": {
		"bool_string": {
			"type": "string",
			"enum": ["False", "True"]
		},
		"decimal_string": {
			"type": "string",
			"pattern": "^\\d+\\.\\d{6}$"
		},
		"decimal_string--signed": {
			"type": "string",
			"pattern": "^-?\\d+\\.\\d{6}$"
		},
		"empty-object": {
			"type": "string",
			"const": "()"
		},
		"integer_string": {
			"type": "string",
			"pattern": "^\\d+$"
		},
		"integer_string--signed": {
			"type": "string",
			"pattern": "^-?\\d+$"
		},
		"BGRA": {
			"type": "string",
			"typed_string": {
				"type": "object",
				"additionalProperties": false,
				"required": ["B", "G", "R", "A"],
				"properties": {
					"B": {
						"$ref": "#/$defs/integer_string"
					},
					"G": {
						"$ref": "#/$defs/integer_string"
					},
					"R": {
						"$ref": "#/$defs/integer_string"
					},
					"A": {
						"$ref": "#/$defs/integer_string"
					}
				}
			}
		},
		"PitchYawRoll--decimal_string--signed": {
			"type": "string",
			"typed_string": {
				"type": "object",
				"additionalProperties": false,
				"required": ["Pitch", "Yaw", "Roll"],
				"properties": {
					"Pitch": {
						"$ref": "#/$defs/decimal_string--signed"
					},
					"Yaw": {
						"$ref": "#/$defs/decimal_string--signed"
					},
					"Roll": {
						"$ref": "#/$defs/decimal_string--signed"
					}
				}
			}
		},
		"RGBA": {
			"type": "string",
			"typed_string": {
				"type": "object",
				"additionalProperties": false,
				"required": ["R", "G", "B", "A"],
				"properties": {
					"R": {
						"$ref": "#/$defs/decimal_string"
					},
					"G": {
						"$ref": "#/$defs/decimal_string"
					},
					"B": {
						"$ref": "#/$defs/decimal_string"
					},
					"A": {
						"$ref": "#/$defs/decimal_string"
					}
				}
			}
		},
		"XY--decimal_string": {
			"type": "string",
			"typed_string": {
				"type": "object",
				"additionalProperties": false,
				"required": ["X", "Y"],
				"properties": {
					"X": {
						"$ref": "#/$defs/decimal_string--signed"
					},
					"Y": {
						"$ref": "#/$defs/decimal_string--signed"
					}
				}
			}
		},
		"XYZ--decimal_string": {
			"type": "string",
			"typed_string": {
				"type": "object",
				"additionalProperties": false,
				"required": ["X", "Y", "Z"],
				"properties": {
					"X": {
						"$ref": "#/$defs/decimal_string--signed"
					},
					"Y": {
						"$ref": "#/$defs/decimal_string--signed"
					},
					"Z": {
						"$ref": "#/$defs/decimal_string--signed"
					}
				}
			}
		},
		"XYZ--decimal_string--list": {
			"type": "string",
			"typed_string": {
				"type": "array",
				"minItems": 1,
				"uniqueItems": true,
				"items": {
					"type": "object",
					"additionalProperties": false,
					"required": ["X", "Y", "Z"],
					"properties": {
						"X": {
							"$ref": "#/$defs/decimal_string--signed"
						},
						"Y": {
							"$ref": "#/$defs/decimal_string--signed"
						},
						"Z": {
							"$ref": "#/$defs/decimal_string--signed"
						}
					}
				}
			}
		},
		"XYZ--integer_string": {
			"type": "string",
			"typed_string": {
				"type": "object",
				"additionalProperties": false,
				"required": ["X", "Y", "Z"],
				"properties": {
					"X": {
						"$ref": "#/$defs/integer_string"
					},
					"Y": {
						"$ref": "#/$defs/integer_string"
					},
					"Z": {
						"$ref": "#/$defs/integer_string"
					}
				}
			}
		},
		"XYZW--decimal_string": {
			"type": "string",
			"typed_string": {
				"type": "object",
				"additionalProperties": false,
				"required": ["X", "Y", "Z", "W"],
				"properties": {
					"X": {
						"$ref": "#/$defs/decimal_string--signed"
					},
					"Y": {
						"$ref": "#/$defs/decimal_string--signed"
					},
					"Z": {
						"$ref": "#/$defs/decimal_string--signed"
					},
					"W": {
						"$ref": "#/$defs/decimal_string--signed"
					}
				}
			}
		}
	}
}
